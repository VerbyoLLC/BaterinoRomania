// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                        String    @id @default(cuid())
  email                     String    @unique
  /** Prenume / nume / telefon afișate în panoul admin (Detalii cont); opțional pentru toate rolurile. */
  firstName                 String    @default("")
  lastName                  String    @default("")
  phone                     String    @default("")
  /** Null pentru conturi create doar cu Google (GIS + ID token). */
  password                  String?
  /** Subject Google (sub) din ID token; unic când e setat. */
  googleSub                 String?   @unique
  role                      String    // "client" | "partener" | "admin" | "sales_agent"
  /** Cod personal de recomandare (clienți B2C); unic, generat la primul acces la profil. */
  referralCode                   String? @unique
  /** Emailuri cu cod trimise din contul client („Trimite pe email”). */
  referralInviteEmailsSent       Int     @default(0)
  /** De câte ori codul tău a fost folosit la comenzi (când e urmărit în fluxul de checkout). */
  referralCodeRedemptionsCount   Int     @default(0)
  verificationCode          String?
  verificationCodeExpiresAt DateTime?
  /** Email nou solicitat (schimbare cont Google) — până la confirmarea codului trimis pe emailul curent. */
  pendingEmailChange        String?
  passwordResetToken        String?
  passwordResetExpiresAt    DateTime?
  /** Coș B2C persistat server-side (JSON linii); folosit doar pentru role client. */
  clientCart                Json?
  /** Consimțământ explicit pentru comunicări comerciale prin email (GDPR). */
  marketingEmailOptIn       Boolean   @default(false)
  marketingEmailOptInAt     DateTime?
  /** Cont marcat pentru ștergere; acces blocat până la anonimizare definitivă (cron 30 zile). */
  deletedAt                 DateTime?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
  partner                   Partner?
  clientProfile             ClientProfile?
  residentialOrders         ResidentialOrder[]
  salesAgentProfile         SalesAgent? @relation("UserSalesAgent")
  retururi                  Retur[]
  adminCommercialOffers     AdminCommercialOffer[]
  commercialOfferNotes      AdminCommercialOfferNote[] @relation("UserOfferNotes")
  salesLeadsCreated         SalesLead[]
  salesLeadActivities       SalesLeadActivity[]
  salesLeadUserStates       SalesLeadUserState[]

  @@index([deletedAt])
}

/** Profil livrare/facturare pentru conturi client (1:1 User). */
model ClientProfile {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName           String   @default("")
  lastName            String   @default("")
  phone               String   @default("")
  billAddress         String   @default("")
  billCounty          String   @default("")
  billCity            String   @default("")
  billPostal          String   @default("")
  deliveryDifferent   Boolean  @default(false)
  delAddress          String?
  delCounty           String?
  delCity             String?
  delPostal           String?
  /** Facturare pe persoană juridică (opțional): date firmă completate în Setări → Date companie. */
  companyName         String   @default("")
  companyCui          String   @default("")
  companyAddress      String   @default("")
  companyCounty       String   @default("")
  companyCity         String   @default("")
  companyPostal       String   @default("")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

/** Comandă rezidențială cu una sau mai multe linii (coș). */
model ResidentialOrder {
  id                String   @id @default(cuid())
  orderNumber       String   @unique
  orderSource       String   @default("guest")
  userId            String?
  user              User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  email             String
  phone             String
  lastName          String
  firstName         String
  billAddress       String
  billCounty        String
  billCity          String
  billPostal        String
  deliveryDifferent Boolean  @default(false)
  delAddress        String?
  delCounty         String?
  delCity           String?
  delPostal         String?
  /** 'person' (Persoană fizică) sau 'company' (Persoană juridică) — controlează proforma și separarea factură/livrare. */
  buyerType         String   @default("person")
  /** Date firmă pentru factură PJ — populate doar când buyerType = 'company'; oglindite în bill* pentru proforma. */
  companyName       String?
  companyCui        String?
  companyAddress    String?
  companyCounty     String?
  companyCity       String?
  companyPostal     String?
  currency          String   @default("RON")
  /** de_platit | preluata | in_pregatire | in_curs_livrare | livrata | anulata — setat din admin sau anulare client. */
  fulfillmentStatus String   @default("de_platit")
  /** Factură PDF încărcată de admin când comanda trece în „în pregătire”; URL public R2. */
  clientInvoiceUrl  String?
  /** Proforma PDF încărcată de admin (R2). */
  proformaUrl       String?
  createdAt         DateTime @default(now())

  lines             ResidentialOrderLine[]

  @@index([email])
  @@index([userId])
  @@index([orderSource])
  @@index([createdAt])
  @@index([fulfillmentStatus])
  @@index([buyerType])
}

model ResidentialOrderLine {
  id               String           @id @default(cuid())
  orderId          String
  order            ResidentialOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId        String
  productSlug      String?
  productTitle     String
  quantity         Int
  unitPriceInclVat Decimal? @db.Decimal(14, 2)
  lineTotalInclVat Decimal? @db.Decimal(14, 2)
  /** Preț catalog / înainte de reducere (cu TVA) — setat doar când s-a aplicat discount la plată. */
  listUnitPriceInclVat Decimal? @db.Decimal(14, 2)
  listLineTotalInclVat Decimal? @db.Decimal(14, 2)
  vatPercent       Decimal? @db.Decimal(5, 2)

  @@index([orderId])
}

model Partner {
  id                    String   @id @default(cuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Profil legal (SignupParteneriProfil)
  companyName           String
  cui                   String
  address               String?
  /** Sediu social (înregistrare): strada și numărul */
  companyStreet         String?
  companyCity           String?
  companyCounty         String?
  companyPostalCode     String?
  /** Magazin / depozit / adresă livrare implicită (distinctă de sediu social și de adresa din profil public). */
  deliveryStreet        String?
  deliveryCounty        String?
  deliveryCity          String?
  deliveryPostalCode    String?
  tradeRegisterNumber   String?
  activityTypes         String   // "instalator,distribuitor,integrator,altul" (comma-separated)
  contactFirstName      String
  contactLastName       String
  phone                 String   // telefon contact principal

  // Profil public (SignupParteneriProfilPublic)
  logoUrl               String?
  publicName            String?
  street                String?
  county                String?
  city                  String?
  zipCode               String?
  description           String?
  services              String?  // "fotovoltaice,baterii,..." (comma-separated)
  publicPhone           String?
  whatsapp              String?
  website               String?
  facebookUrl           String?
  linkedinUrl           String?
  instagramUrl          String?
  tiktokUrl             String?
  /** Galerie foto lucrări — JSON array de URL-uri / base64 (max 8). */
  workPhotos            String?
  /** Handle URL public /companii/{publicSlug}; implicit unic din denumirea companiei; prefix „@” e opțional în URL. */
  publicSlug           String?  @unique
  isPublic              Boolean  @default(true)
  isSuspended           Boolean  @default(false)
  isApproved            Boolean  @default(false)  // aprobat de admin
  /** Setat când s-a trimis emailul „cerere primită / în așteptare” (un singur mesaj per cont). */
  applicationReceivedEmailSentAt DateTime?
  partnerDiscountPercent Float?   // reducere % acordată de admin (ex: 10 = 10% off)
  /** Agent de vânzări atribuit (SalesAgent.id). */
  assignedSalesAgentId  String?
  assignedSalesAgent    SalesAgent? @relation("PartnerAssignedSalesAgent", fields: [assignedSalesAgentId], references: [id], onDelete: SetNull)

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([assignedSalesAgentId])
}

model ReducereProgram {
  id              String   @id @default(cuid())
  locale          String   // "ro" | "en" | "zh"
  photo           String
  programLabel    String
  title           String
  descriereScurta String?
  description     String
  ctaLabel        String   @default("CREEAZĂ CONT")
  ctaTo           String   @default("/login")
  termsLabel      String
  topIcon         String?
  stiaiCaTitle    String?
  stiaiCaText     String?
  durataProgram   String?
  discountPercent Int?
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CaseStudy {
  id         String   @id @default(cuid())
  locale     String   // "ro" | "en" | "zh"
  slug       String
  category   String
  title      String
  location   String
  image      String
  imageAlt   String
  imageCount Int      @default(0)
  /** Up to 6 gallery URLs (R2: study-cases/{slug}/). First entry mirrors `image`. */
  images     Json     @default("[]")
  specs      Json     @default("[]")
  tags       Json     @default("[]")
  isActive   Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([locale, slug])
  @@index([locale, isActive, sortOrder])
}

model Inquiry {
  id                 String   @id @default(cuid())
  registrationNumber String?  @unique
  name               String
  company            String
  email              String
  domain             String   // "rezidential" | "industrial" | "medical" | "maritim"
  requestType        String   // "sales" | "technical" | "service" | "partnership"
  message            String   @db.Text
  ip                 String?
  isRead             Boolean  @default(false)
  createdAt          DateTime @default(now())
}

model Product {
  id                    String   @id @default(cuid())
  status                String   @default("draft") // "draft" | "published"

  // Basic
  brand                 String?
  title                 String
  slug                  String?  @unique // URL slug for SEO, e.g. "baterie-hp-2000"
  sku                   String   @unique
  description           String?
  subtitle              String?  // short line under hero title (rezidential / industrial layout)
  overview              String?  @db.Text // overview section body (rezidential industrial-style page)
  /** Optional SEO overrides for /produse/:slug (empty = derive from title/description/overview) */
  seoTitle              String?
  seoDescription        String?  @db.Text
  seoOgImage            String? // absolute or site-relative image URL for Open Graph
  tipProdus             String   // "rezidential" = pagină clasică (specificații, preț) | "industrial" = șablon carousel (overview, avantaje)
  categorie             String?  // comma-separated: "rezidential,industrial,medical,maritim"

  // Price (may be redacted in public API for guests when priceVisibility ≠ public)
  landedPrice           Decimal  @db.Decimal(12, 2)
  salePrice             Decimal  @db.Decimal(12, 2)
  /** Preț catalog partener (fără TVA); 0 = neconfigurat */
  partnerSalePrice      Decimal  @default(0) @db.Decimal(12, 2)
  vat                   Decimal  @db.Decimal(5, 2)
  /** hidden | public | partner_only */
  priceVisibility       String   @default("public")
  /** simple | detailed — UI only; does not affect SEO */
  pricePresentation     String   @default("simple")
  /** Rezidențial: etichetă colț imagine card — in_stock | out_of_stock | coming_soon */
  catalogStockStatus    String?
  /** Rezidențial: etichetă livrare pe card — 24h | 48h | 7_14d | 60d */
  catalogDeliveryBadge  String?
  /** Rezidențial: etichetă transport pe card — free | paid */
  catalogTransportBadge String?
  /** Industrial: etichetă instalare pe card — baterino | partner */
  catalogInstallBadge   String?
  /** Rezidențial: id-uri ReducereProgram (API) pentru dropdown „programe reducere”; [] = toate (compat). */
  reducereProgramIds    Json     @default("[]")

  /** Prioritate în liste cont client / cont partener (admin). */
  promovarePeContClient   Boolean  @default(false)
  promovarePeContPartener Boolean  @default(false)

  // Technical details
  energieNominala       String?
  capacitate            String?
  curentMaxDescarcare   String?
  curentMaxIncarcare    String?
  cicluriDescarcare     String?
  adancimeDescarcare    String?
  greutate              String?
  compozitie            String?  // e.g. "LiFePo4"
  dimensiuni            String?
  protectie             String?
  conectivitateWifi     Boolean  @default(false)
  conectivitateBluetooth Boolean @default(false)
  protectieFoc          String?  // "protectie" | "fara"
  certificari           String?
  garantie              String?
  tensiuneNominala      String?
  locatieMontaj         String?  // "indoor" | "outdoor" | null
  eficientaCiclu        String?
  temperaturaFunctionare String?
  temperaturaStocare    String?
  umiditate             String?

  cardImage             String?  // URL pentru card (listă, acasă); altfel prima din `images`
  // Arrays stored as JSON
  images                Json     @default("[]") // string[] URLs
  keyAdvantages         Json     @default("[]") // { title: string, image: string }[] — carousel cards on industrial-style residential page
  documenteTehnice      Json     @default("[]") // { descriere: string, url: string }[]
  faq                   Json     @default("[]") // { q: string, a: string }[]
  /** Rezidențial / industrial PDP: exemple instalări { title, subtitle, location, image }[] */
  caseStudyExamples     Json     @default("[]")
  alimentaModalContent  Json?    // { title, intro?, sections: [{ label, items: string[] }] } — product-specific "Ce se poate alimenta" modal
  /** Industrial: { entries: [{ modelName, specs: Record<string,string> }] }; legacy { models, rows } also supported when reading */
  technicalSpecsModels  Json?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  /** Unități fizice înregistrate în depozit (SN + model catalog). */
  warehouseStockUnits   WarehouseStockUnit[]
}

/** Unitate fizică în depozit: număr unic de serie legat de un produs (model) din catalog. */
model WarehouseStockUnit {
  id                    String   @id @default(cuid())
  productId             String
  product               Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  /** Număr serie unic (din QR sau introdus manual). */
  serialNumber          String   @unique
  /** Data intrării în depozitul Baterino — setată automat la înregistrare. */
  warehouseReceivedAt   DateTime @default(now())
  /** qr_scan | manual */
  entryMethod           String
  /** Conținut brut decodat din QR (audit). */
  rawQrPayload          String?  @db.Text
  savedItem             WarehouseSavedItem?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([productId])
  @@index([warehouseReceivedAt])
}

/** Locație fizică / etapă logistică pentru rândul din Stocuri → Lista. */
enum WarehouseSavedItemLocation {
  depozit
  distribuitor
  client_final
  service
}

/** Rânduri dedicate pentru lista salvată din Stocuri → Lista. */
model WarehouseSavedItem {
  id                   String                     @id @default(cuid())
  /** Număr de item în depozit, incrementat automat (0001, 0002, ... pentru afișare). */
  itemNumber           Int                        @unique @default(autoincrement())
  warehouseStockUnitId String                     @unique
  warehouseStockUnit   WarehouseStockUnit         @relation(fields: [warehouseStockUnitId], references: [id], onDelete: Cascade)
  modelNumber          String
  serialNumber         String                     @unique
  /** Formatted as MM/YYYY; derived from SN (cifrele 9–10 = an YY, 11–12 = lună în cele 16 cifre după LJC). */
  producedOn           String                     @default("")
  warehouseIn          DateTime                   @default(now())
  /** La intrare în depozit se setează automat `depozit`; poate fi actualizat ulterior. */
  location             WarehouseSavedItemLocation @default(depozit)
  distributor          String?
  client               String?
  /** URL public R2 către PDF-ul certificatului de garanţie generat (null = neg generat încă). */
  warrantyCertificateUrl String?                  @db.Text
  /** Timestamp-ul ultimei generări a certificatului. */
  warrantyCertificateGeneratedAt DateTime?
  /** Data recepției produsului de către client (ex. zz-ll-aaaa); opțional. */
  clientReceiptDate    String?
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt

  @@index([warehouseIn])
  @@index([location])
}

/**
 * Modele produs (referință tehnică) — admin Inventar → Modele.
 * Tabel DB: product_models.
 */
model ProductModel {
  id                   String   @id @default(cuid())
  name                 String
  brand                String
  series               String   @default("")
  modelNumber          String   @unique
  technicalDescription String   @db.Text
  /** industrial | residential */
  usageType            String   @default("industrial")
  /** ESS | INV | PV | PCS | BMS | ACC | CHG */
  productType          String   @default("ESS")
  /** Auto-generated: Brand-Type-ModelNumber */
  sku                  String   @default("")
  imageUrl             String?  @db.Text
  /** 600×600 catalog image for the product model (uploaded via admin cropper). */
  productImageUrl      String?  @db.Text
  /** When true, model appears in Stocuri → Add Item model dropdown. */
  availableForStock  Boolean  @default(true)
  sortOrder            Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([sortOrder])
  @@index([availableForStock])
  @@map("product_models")
}

/** Telefon principal și WhatsApp per departament (admin). Chei: general | rezidential | industrial | medical | maritim */
model DepartmentPhone {
  department String   @id
  phone      String   @default("")
  whatsapp   String   @default("")
  updatedAt  DateTime @updatedAt
}

/** Setări site cheie–valoare (ex. catalog_currency = EUR | RON | …) */
model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

/** Date firmei Baterino (facturi, documente) — un singur rând, id fix „default”. */
model BaterinoCompany {
  id                 String               @id @default("default")
  name               String               @default("Baterino SRL")
  cui                String               @default("")
  address            String               @default("")
  /** Reprezentant legal/oficial al companiei. Se afişează pe certificatul de garanţie la „Reprezentant furnizor”. */
  representativeName String               @default("")
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  bankAccounts       CompanyBankAccount[]
}

model CompanyBankAccount {
  id          String          @id @default(cuid())
  companyId   String          @default("default")
  company     BaterinoCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  bankName    String          @default("")
  iban        String          @default("")
  swift       String          @default("")
  /** Monedă cont: RON | EUR | USD (afișare admin: RON / EURO / USD). */
  currency    String          @default("RON")
  accountName String          @default("")
  sortOrder   Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([companyId])
}

/** Comandă invitat flux rezidențial /comanda — urmărită prin orderNumber + email. */
model GuestResidentialOrder {
  id           String  @id @default(cuid())
  orderNumber  String  @unique
  /** guest = fără cont / anonim; client = JWT rol client la plasare */
  orderSource  String  @default("guest")
  email        String
  /** 9 cifre naționale (fără +40) */
  phone        String
  lastName     String
  firstName    String
  billAddress  String
  billCounty   String
  billCity     String
  billPostal   String
  deliveryDifferent Boolean @default(false)
  delAddress   String?
  delCounty    String?
  delCity      String?
  delPostal    String?
  /** 'person' | 'company' — păstrat pentru paritate cu ResidentialOrder pe rândurile legacy. */
  buyerType    String   @default("person")
  companyName  String?
  companyCui   String?
  companyAddress String?
  companyCounty  String?
  companyCity    String?
  companyPostal  String?
  productId    String
  productSlug  String?
  productTitle String
  quantity     Int
  currency     String   @default("RON")
  unitPriceInclVat Decimal? @db.Decimal(14, 2)
  lineTotalInclVat Decimal? @db.Decimal(14, 2)
  listUnitPriceInclVat Decimal? @db.Decimal(14, 2)
  listLineTotalInclVat Decimal? @db.Decimal(14, 2)
  vatPercent       Decimal? @db.Decimal(5, 2)
  /** de_platit | preluata | in_pregatire | in_curs_livrare | livrata | anulata */
  fulfillmentStatus String   @default("de_platit")
  clientInvoiceUrl  String?
  proformaUrl       String?
  createdAt    DateTime @default(now())

  @@index([email])
  @@index([orderSource])
  @@index([createdAt])
  @@index([fulfillmentStatus])
  @@index([buyerType])
}

/**
 * Cerere de service trimisă de un client (sau partener, în viitor) pentru un
 * produs înregistrat. Datele despre cont și produs sunt copii (snapshot) la
 * momentul trimiterii, ca să rămână stabile dacă utilizatorul își modifică
 * profilul sau dacă produsul se schimbă în catalog.
 *
 * status: open | in_progress | resolved | closed
 *   - open: tocmai creată, neasumată încă de echipă
 *   - in_progress: în lucru (UI client afișează „În desfășurare”)
 *   - resolved: rezolvată
 *   - closed: închisă fără rezolvare (refuzată / duplicat / etc.)
 *
 * Pe frontend, atât `open` cât și `in_progress` se traduc în „În desfășurare”
 * pentru client (orice cerere care nu este `resolved` sau `closed`).
 */
model ServiceRequest {
  id                  String   @id @default(cuid())
  /** BTROS-YYYYMMDD-NNNN — afișat utilizatorului în email și UI. */
  requestNumber       String   @unique
  /** client | partener (rolul contului la momentul trimiterii). */
  accountType         String
  userId              String?
  /** Snapshot date cont la momentul trimiterii. */
  firstName           String   @default("")
  lastName            String   @default("")
  email               String
  phone               String   @default("")
  /** Snapshot produs (SN unic - dar nu legăm prin FK ca să nu rupem dacă unitatea se șterge). */
  serialNumber        String
  modelNumber         String
  productTitle        String
  /** ID rând WarehouseSavedItem (link logic, fără FK constraint). */
  savedItemId         String?
  /** Descrierea problemei completată de utilizator. */
  problemDescription  String   @db.Text
  /** open | in_progress | resolved | closed */
  status              String   @default("open")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([userId])
  @@index([email])
  @@index([serialNumber])
  @@index([status])
  @@index([createdAt])
}

/**
 * Cerere de retur trimisă din site (formular Returnare produse).
 * id numeric (SERIAL) — folosit intern; seria publică afișată este BTRT-{id zero-padded}.
 * Fotografiile sunt în R2: `retur/<orderSlug>-<id>/`.
 */
model Retur {
  id                  Int      @id @default(autoincrement())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  userId              String?
  user                User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  /** guest | client — sursa trimiterii. */
  submitSource        String   @default("guest")

  lastName            String   @default("")
  firstName           String   @default("")
  street              String   @default("")
  county              String   @default("")
  city                String   @default("")
  postal              String   @default("")
  phone               String   @default("")
  email               String   @default("")

  orderNumber         String
  receiptDate         String
  serialNumber        String
  productBrand        String
  productModel        String

  returnReason        String
  returnReasonOther   String   @default("") @db.Text

  condUninstalled     Boolean
  condSeals           Boolean
  condPackaging       Boolean

  pickupStreet        String   @default("")
  pickupCounty        String   @default("")
  pickupCity          String   @default("")
  pickupPostal        String   @default("")

  refundTitular       String   @default("")
  refundIban          String   @default("")

  policyAccepted      Boolean
  declarationAccepted Boolean

  locale              String   @default("ro")

  /** Listă URL-uri publice R2 (JSON array de string-uri). */
  conditionPhotoUrls  Json     @default("[]")

  /** pending | reviewed | closed */
  status              String   @default("pending")

  @@index([userId])
  @@index([orderNumber])
  @@index([createdAt])
  @@index([email])
  @@map("retur")
}

/** Agenți de vânzări / teren — admin Setări → Agenți; opțional legat de cont User (rol sales_agent). */
model SalesAgent {
  id        String   @id @default(cuid())
  lastName  String   @default("")
  firstName String   @default("")
  phone     String   @default("")
  whatsapp  String   @default("")
  email     String   @default("")
  /** Program (ex. L–V 9–17). */
  program   String   @default("")
  county    String   @default("")
  city      String   @default("")
  sector    String   @default("")
  /** "human" | "ai" — tip agent (uman sau AI). */
  agentKind String   @default("human")
  isSuspended Boolean @default(false)
  deletedAt DateTime?
  userId    String?  @unique
  user      User?    @relation("UserSalesAgent", fields: [userId], references: [id], onDelete: SetNull)
  partners  Partner[] @relation("PartnerAssignedSalesAgent")
  salesLeads SalesLead[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([deletedAt])
}

/** Ofertă comercială generată din admin — PDF în R2 + metadate pentru listă. */
model AdminCommercialOffer {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  /** draft | generated */
  status          String   @default("generated")
  /** person | company */
  buyerType       String
  clientLabel     String
  clientEmail     String   @default("")
  clientPhone     String   @default("")
  /** Contact client la generare (fallback listă dacă coloanele dedicate sunt goale). */
  draftSnapshot   Json?
  amountGross     Decimal  @db.Decimal(14, 2)
  currency        String
  productCount    Int
  pdfUrl          String
  createdByUserId String?
  createdBy       User?    @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  notes           AdminCommercialOfferNote[]

  @@index([createdAt])
  @@index([buyerType])
  @@index([status])
  @@map("admin_commercial_offer")
}

/** Notă internă atașată unei oferte comerciale. */
model AdminCommercialOfferNote {
  id          String               @id @default(cuid())
  createdAt   DateTime             @default(now())
  offerId     String
  offer       AdminCommercialOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  authorId    String?
  author      User?                @relation("UserOfferNotes", fields: [authorId], references: [id], onDelete: SetNull)
  authorName  String               @default("")
  body        String

  @@index([offerId])
  @@index([createdAt])
  @@map("admin_commercial_offer_note")
}

/** Lead comercial — creat de agent vânzări sau (viitor) din alte surse. */
model SalesLead {
  id              String      @id @default(cuid())
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  name            String
  email           String      @default("")
  phone           String      @default("")
  source          String      @default("Manual")
  /** nou | contactat | oferta | inchis */
  status          String      @default("nou")
  customerType    String      @default("")
  productLine     String      @default("")
  monthlyVolume   String      @default("")
  whatsapp        String      @default("")
  message         String      @default("")
  companyName     String      @default("")
  workEmail       String      @default("")
  jobTitle        String      @default("")
  country         String      @default("")
  website         String      @default("")
  salesAgentId    String?
  salesAgent      SalesAgent? @relation(fields: [salesAgentId], references: [id], onDelete: SetNull)
  createdByUserId String?
  createdBy       User?       @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  activities      SalesLeadActivity[]
  userStates      SalesLeadUserState[]

  @@index([createdAt])
  @@index([salesAgentId])
  @@index([status])
  @@index([createdByUserId])
  @@map("sales_lead")
}

/** Comentariu sau schimbare status pe un lead (contribuții agent). */
model SalesLeadActivity {
  id         String    @id @default(cuid())
  createdAt  DateTime  @default(now())
  leadId     String
  lead       SalesLead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /** comment | status_change */
  type       String
  comment    String    @default("")
  fromStatus String    @default("")
  toStatus   String    @default("")

  @@index([leadId])
  @@index([userId])
  @@index([type])
  @@map("sales_lead_activity")
}

/** Stare citire lead per utilizator (admin / agent). */
model SalesLeadUserState {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  leadId         String
  lead           SalesLead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  /** Prima deschidere panou detalii. */
  viewedAt       DateTime?
  /** Ultima deschidere panou comentarii. */
  commentsSeenAt DateTime?

  @@unique([userId, leadId])
  @@index([userId])
  @@index([leadId])
  @@map("sales_lead_user_state")
}

/**
 * Jurnal imutabil de consimțământ (GDPR / ANSPDCP).
 * Fără FK către User — rândurile rămân după ștergerea contului, cu userId intact.
 */
model ConsentLog {
  id          String   @id @default(cuid())
  userId      String?
  consentType String
  granted     Boolean
  ipAddress   String?  @db.VarChar(45)
  userAgent   String?  @db.Text
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([consentType])
  @@index([createdAt])
  @@map("consent_log")
}
