# ═══════════════════════════════════════════════════════════════
# Baterino API – Environment variables
# Copiază în .env și completează. Nu comita .env (e în .gitignore).
# Pentru Railway: setează în Dashboard → Variables.
# ═══════════════════════════════════════════════════════════════

# ── OBLIGATORII ──
# Database (Railway: auto-setat când adaugi PostgreSQL)
DATABASE_URL="postgres://user:pass@host:5432/dbname"

# JWT secret – generează cu: openssl rand -hex 32
JWT_SECRET="change-in-production"

# Port HTTP API local (implicit 3000; Vite dev pe 5173 proxy-ează /api aici)
PORT=3000

# URL frontend (pentru linkuri în emailuri, reset parolă)
FRONTEND_URL="http://localhost:5173"
# Link „ACCESEAZĂ CONTUL TĂU” din emailul de aprobare partener (implicit: app.baterino.com/login)
# PARTNER_LOGIN_URL="https://app.baterino.com/login"
# Email suport în emailurile partener (implicit: suport@baterino.ro)
# PARTNER_SUPPORT_EMAIL="suport@baterino.ro"
# Expeditor emailuri partener (welcome etc.; implicit: parteneri@baterino.ro)
# PARTNER_MAIL_FROM="Baterino Partener <parteneri@baterino.ro>"
# Expeditor emailuri cont (verificare, reset parolă, referral, ștergere cont; implicit: conturi@baterino.ro)
# ACCOUNTS_MAIL_FROM="Baterino <conturi@baterino.ro>"
# Expeditor emailuri comenzi rezidențiale + alertă admin comandă nouă (implicit: comenzi@baterino.ro)
# ORDERS_MAIL_FROM="Baterino Comenzi <comenzi@baterino.ro>"
# SERVICE_MAIL_FROM="Baterino Service <service@baterino.ro>"
# Telefon suport (implicit: +40 770 106 374 dacă lipsește din DB)
# BATERINO_SUPPORT_PHONE="+40 770 106 374"
# Link panou agent în emailul de partener nou atribuit (implicit: FRONTEND_URL/sales-agent)
# SALES_AGENT_PANEL_URL="https://app.baterino.com/sales-agent"

# ── OPȚIONAL – Google Sign-In (GIS/FedCM + ID token) ──
# OAuth 2.0 Client ID (Web) din Google Cloud Console.
# Poți include mai multe client IDs separate prin virgulă/spațiu (ex. local + production).
# Același client ID: în Google Cloud → OAuth client → „Authorized JavaScript origins”
# include originul frontend-ului (ex. http://localhost:5173), altfel: unregistered_origin.
#
# Client secret (din aceeași pagină Credentials) NU este folosit în acest proiect:
# fluxul actual trimite ID token de la browser la API, iar verifyIdToken() verifică JWT-ul
# cu cheile publice Google — fără secret. NU pune secretul în apps/web (ar fi expus în bundle).
# Un eventual GOOGLE_CLIENT_SECRET ar fi doar pentru un flux „authorization code” pe server,
# care nu e implementat aici.
GOOGLE_CLIENT_ID=""

# ── R2 (obligatoriu pentru upload imagini/documente produse) ──
# Cloudflare R2 → Manage R2 API Tokens + bucket Settings
R2_ENDPOINT="https://YOUR_ACCOUNT_ID.eu.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="baterinoromania"
R2_PUBLIC_URL="https://media.baterino.ro"
# Broșuri PDF fișă tehnică (admin → Șabloane produse): cheie R2 „Product Technical Brochures/<nume-model>.pdf” (generat în cod; în consola R2 apare ca prefix).

# ── OPȚIONAL – Email (cod verificare, reset parolă) ──
#
# Recomandat: Resend (resend.com → API Keys). Modul implicit „auto” folosește Resend
# când RESEND_API_KEY e setat, chiar dacă ai încă variabile SMTP în mediu.
#
# SMTP direct (SiteGround etc.): doar dacă nu folosești Resend; sau setează MAIL_DRIVER=smtp
# ca să forțezi relay SMTP chiar cu RESEND_API_KEY prezent.
#
# Resend: resend.com → API Keys
RESEND_API_KEY=
RESEND_FROM="Baterino <onboarding@resend.dev>"
# Valori: auto | smtp | resend — auto = Resend dacă există cheie, altfel SMTP dacă e complet
# MAIL_DRIVER=auto
#
# SiteGround SMTP (exemplu — hostul exact e în Site Tools → Email → Mail Configuration):
# SMTP_HOST=mail.domeniultau.ro
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=contact@domeniultau.ro
# SMTP_PASS=...
# MAIL_FROM și VERIFICATION_MAIL_FROM: aceeași adresă ca SMTP_USER (sau alias permis de SiteGround)
SMTP_HOST=
SMTP_PORT=587
# 587 → STARTTLS: SMTP_SECURE=false. 465 → implicit TLS: SMTP_SECURE=true (sau lasă gol pe 465)
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Baterino <noreply@tudomeniu.com>"
SITE_NAME="Baterino Romania"

# Emailuri admin pentru comenzi noi, parteneri de aprobat, contact (implicit: alexander@baterino.ro, razvan@baterino.ro)
# ADMIN_NOTIFICATION_EMAILS="alexander@baterino.ro,razvan@baterino.ro"
# Destinatari link reset parolă admin — mapare per cont (adminEmail=notifyEmail)
# ADMIN_PASSWORD_RESET_NOTIFY_MAP="admin@baterino.ro=razvanalexander99@gmail.com,razvan@baterino.ro=razvan.componente@gmail.com"
# Fallback dacă contul nu e în mapă: ADMIN_PASSWORD_RESET_NOTIFY_EMAILS sau ADMIN_NOTIFICATION_EMAILS
# ADMIN_PASSWORD_RESET_NOTIFY_EMAILS="alexander@baterino.ro,razvan@baterino.ro"

# Email „From” pentru linkul de confirmare la înregistrare (Resend: verifică domeniul baterino.ro)
# VERIFICATION_MAIL_FROM — alias vechi pentru ACCOUNTS_MAIL_FROM
# VERIFICATION_MAIL_FROM="Baterino <conturi@baterino.ro>"

# ── OPȚIONAL – Previzualizare șablon proformă HTML în producție ──
# Local: deschide GET /api/proforma-template (fără variabilă). În NODE_ENV=production ruta răspunde 403 până setezi:
# BATERINO_DEBUG_PROFORMA=1

# ── OPȚIONAL – Verificare garanție publică (GET /api/warranty-verify) ──
# Pe Railway / Vercel rewrite: setează 1 ca Express să folosească X-Forwarded-For → req.ip (rate limit per client).
# TRUST_PROXY=1
# Max. verificări / minut / IP (implicit 40). Anti-enumerare SN din query.
# WARRANTY_VERIFY_MAX_PER_IP_PER_MIN=40
# Dezactivează limitarea (doar dev / test).
# WARRANTY_VERIFY_RATE_LIMIT_DISABLED=1
#
# Link semnat în QR pe certificatul PDF (?t=… în loc de ?sn=…). Generează cu: openssl rand -hex 32
# Fără secret: QR rămâne cu ?sn= (compat); cu secret: token HMAC, verificare fără login.
# WARRANTY_VERIFY_TOKEN_SECRET=""
# TTL token în secunde (implicit ~10 ani; minim 120 în cod).
# WARRANTY_VERIFY_TOKEN_TTL_SEC=
