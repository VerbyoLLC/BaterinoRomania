# ═══════════════════════════════════════════════════════════════
# Baterino API – Environment variables
# Copiază în .env și completează. Nu comita .env (e în .gitignore).
# Pentru Railway: setează în Dashboard → Variables.
# ═══════════════════════════════════════════════════════════════

# ── OBLIGATORII ──
# Database (Railway: auto-setat când adaugi PostgreSQL)
DATABASE_URL="postgres://user:pass@host:5432/dbname"

# JWT secret – generează cu: openssl rand -hex 32
JWT_SECRET="change-in-production"

# URL frontend (pentru linkuri în emailuri, reset parolă)
FRONTEND_URL="http://localhost:5173"

# ── OPȚIONAL – Google Sign-In (GIS/FedCM + ID token) ──
# OAuth 2.0 Client ID (Web) din Google Cloud Console.
# Poți include mai multe client IDs separate prin virgulă/spațiu (ex. local + production).
GOOGLE_CLIENT_ID=""

# ── R2 (obligatoriu pentru upload imagini/documente produse) ──
# Cloudflare R2 → Manage R2 API Tokens + bucket Settings
R2_ENDPOINT="https://YOUR_ACCOUNT_ID.eu.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="baterinoromania"
R2_PUBLIC_URL="https://media.baterino.ro"

# ── OPȚIONAL – Email (cod verificare, reset parolă) ──
#
# Recomandat: Resend (resend.com → API Keys). Modul implicit „auto” folosește Resend
# când RESEND_API_KEY e setat, chiar dacă ai încă variabile SMTP în mediu.
#
# SMTP direct (SiteGround etc.): doar dacă nu folosești Resend; sau setează MAIL_DRIVER=smtp
# ca să forțezi relay SMTP chiar cu RESEND_API_KEY prezent.
#
# Resend: resend.com → API Keys
RESEND_API_KEY=
RESEND_FROM="Baterino <onboarding@resend.dev>"
# Valori: auto | smtp | resend — auto = Resend dacă există cheie, altfel SMTP dacă e complet
# MAIL_DRIVER=auto
#
# SiteGround SMTP (exemplu — hostul exact e în Site Tools → Email → Mail Configuration):
# SMTP_HOST=mail.domeniultau.ro
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=contact@domeniultau.ro
# SMTP_PASS=...
# MAIL_FROM și VERIFICATION_MAIL_FROM: aceeași adresă ca SMTP_USER (sau alias permis de SiteGround)
SMTP_HOST=
SMTP_PORT=587
# 587 → STARTTLS: SMTP_SECURE=false. 465 → implicit TLS: SMTP_SECURE=true (sau lasă gol pe 465)
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Baterino <noreply@tudomeniu.com>"
SITE_NAME="Baterino Romania"

# Email „From” pentru linkul de confirmare la înregistrare (Resend: verifică domeniul baterino.ro)
# VERIFICATION_MAIL_FROM="Baterino <no-reply@baterino.ro>"

# ── OPȚIONAL – Previzualizare șablon proformă HTML în producție ──
# Local: deschide GET /api/proforma-template (fără variabilă). În NODE_ENV=production ruta răspunde 403 până setezi:
# BATERINO_DEBUG_PROFORMA=1
