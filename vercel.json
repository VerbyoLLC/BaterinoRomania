{
  "buildCommand": "npm run build",
  "outputDirectory": "apps/web/dist",
  "installCommand": "npm install && npm install --prefix apps/web",
  "framework": "vite",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "baterino.ro" }],
      "destination": "https://www.baterino.ro/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "https://baterinoromania-production.up.railway.app/api/sitemap.xml" },
    {
      "source": "/produse/:path*",
      "has": [
        {
          "type": "header",
          "key": "User-Agent",
          "value": "(?i).*(facebookexternalhit|meta-externalagent|facebookcatalog|twitterbot|linkedinbot|whatsapp|telegrambot|slackbot|discordbot|pinterestbot|redditbot|skypeuripreview|applebot).*"
        }
      ],
      "destination": "/api/og?path=/produse/:path*"
    },
    { "source": "/api/(?!og$)(.*)", "destination": "https://baterinoromania-production.up.railway.app/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
